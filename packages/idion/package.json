{
  "name": "@herodot-app/idion",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/idion.cjs",
  "module": "./dist/idion.js",
  "types": "./dist/idion.d.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/idion.d.ts",
      "import": "./dist/idion.js",
      "require": "./dist/idion.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dist": "tsup"
  },
  "tsup": {
    "entry": [
      "src/idion.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "outDir": "dist",
    "minify": false
  }
}
