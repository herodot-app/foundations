{
  "name": "@herodot-app/sema",
  "description": "A typescript implementation of reactive values that can be observable and derived in order to make your codebase a reactive place where changes are tracked and things react between them",
  "license": "MIT",
  "keywords": [
    "typescript",
    "library"
  ],
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dist": "tsup",
    "lint": "biome check && tsc --noEmit"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "sourcemap": true,
    "clean": true,
    "outDir": "dist",
    "minify": false
  },
  "dependencies": {
    "@herodot-app/agora": "^1.1.0",
    "@herodot-app/idion": "^0.1.3",
    "@herodot-app/ptoma": "^0.2.1",
    "@herodot-app/rheon": "^0.3.0",
    "@herodot-app/zygon": "^1.0.0"
  }
}
